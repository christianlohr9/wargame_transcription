{
  "name": "blackbox-desktop",
  "version": "1.0.0",
  "description": "Blackbox Desktop - Electron shell for wargaming platform",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:frontend": "cd ../blackbox/frontend && npx quasar build",
    "build:mac": "electron-builder --mac --dir",
    "build:win": "electron-builder --win",
    "build:all": "bash scripts/build-app.sh"
  },
  "dependencies": {
    "electron-log": "^5.3.0",
    "electron-store": "^10.0.0",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
